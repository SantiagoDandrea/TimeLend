# This file documents the environment variables expected by the frontend module.
# It exists so local development and Vercel configuration start from the same contract.
# It fits the system by separating public browser config from private backend secrets.
NEXT_PUBLIC_APP_NAME=TimeLend Demo
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
NEXT_PUBLIC_CONTRACT_ADDRESS=0xA9b37103aBBE51f04D78751Fe3F4c6286306f595
# Server-only variable used by the internal demo proxy routes.
INTERNAL_API_KEY=
